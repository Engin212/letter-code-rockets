# Copy this file to .env.deploy and fill in your values.
# .env.deploy is gitignored so your server details stay local.
#
# Usage: cp .env.deploy.example .env.deploy && $EDITOR .env.deploy

# SSH user on the target server
DEPLOY_USER=your-ssh-user

# SSH host (must be reachable and configured for key-based auth)
DEPLOY_HOST=example.com

# Absolute path on the server where the static bundle should be synced.
# For Caddy with a bind-mounted sites/ volume, this is typically something like:
#   /home/<user>/docker-services/caddy/sites/static/<site-name>/public
DEPLOY_PATH=/path/to/static/site/public

# Public URL used for a post-deploy HTTP 2xx verification (redirects followed).
DEPLOY_URL=https://your-domain.example.com/

# One-time setup on the remote BEFORE the first deploy:
#
#   ssh $DEPLOY_USER@$DEPLOY_HOST 'mkdir -p $DEPLOY_PATH && touch $DEPLOY_PATH/.deploy-marker'
#
# The .deploy-marker file is a safety opt-in that proves DEPLOY_PATH is a
# directory you intentionally created for deploys. The script refuses to run
# without it, so a typo in DEPLOY_PATH can never let rsync --delete wipe the
# wrong directory. The marker is excluded from rsync and persists across
# deploys.
